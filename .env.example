# Database
DB_USER=taskpulse
DB_PASSWORD=taskpulse123
DB_NAME=taskpulse_db
DATABASE_URL=postgresql://taskpulse:taskpulse123@localhost:5432/taskpulse_db

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production

# API
PORT=3001
NODE_ENV=development

# WhatsApp Integration - Choose one provider
WHATSAPP_PROVIDER=msg91  # Options: msg91 or gupshup

# Msg91 Configuration
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_ROUTE=1
MSG91_TEMPLATE_TASK_ASSIGNED=your_template_id_for_task_assigned
MSG91_TEMPLATE_TASK_COMPLETED=your_template_id_for_task_completed

# Gupshup Configuration
GUPSHUP_API_KEY=your_gupshup_api_key_here
GUPSHUP_APP_NAME=your_gupshup_app_name_here
GUPSHUP_TEMPLATE_TASK_ASSIGNED=your_template_id_for_task_assigned
GUPSHUP_TEMPLATE_TASK_COMPLETED=your_template_id_for_task_completed

# Frontend URLs
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
