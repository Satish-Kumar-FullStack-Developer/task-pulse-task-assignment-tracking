generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MANAGER
  EMPLOYEE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  APPROVED
  RETURNED
}

enum TaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_STARTED
  TASK_COMPLETED
  TASK_RETURNED
  COMMENT_ADDED
  TASK_APPROVED
}

enum NotificationChannel {
  IN_APP
  WHATSAPP
}

enum WhatsAppDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String
  role          UserRole @default(EMPLOYEE)
  phone         String?  @unique
  managerId     String?
  manager       User?    @relation("TeamMembers", fields: [managerId], references: [id], onDelete: SetNull)
  teamMembers   User[]   @relation("TeamMembers")
  
  // Relations
  createdTasks  Task[]   @relation("CreatedBy")
  assignedTasks Task[]   @relation("AssignedTo")
  comments      Comment[]
  notifications Notification[]
  timeLogs      TimeLog[]
  
  // Metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([managerId])
  @@index([role])
}

model Task {
  id            String       @id @default(cuid())
  title         String
  description   String?
  status        TaskStatus   @default(PENDING)
  priority      TaskPriority @default(MEDIUM)
  dueDate       DateTime?
  
  creatorId     String
  creator       User         @relation("CreatedBy", fields: [creatorId], references: [id], onDelete: Cascade)
  
  assigneeId    String
  assignee      User         @relation("AssignedTo", fields: [assigneeId], references: [id], onDelete: Cascade)
  
  // Task execution
  startedAt     DateTime?
  completedAt   DateTime?
  approvedAt    DateTime?
  
  // Relations
  comments      Comment[]
  timeLogs      TimeLog[]
  notifications Notification[]
  deliveryLogs  DeliveryLog[]
  
  // Metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([creatorId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([createdAt])
}

model TimeLog {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  startTime DateTime
  endTime   DateTime?
  duration  Int?      // in seconds
  
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([userId])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  content   String
  isSystem  Boolean  @default(false) // true for auto-posted returns
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([authorId])
  @@index([createdAt])
}

model Notification {
  id           String              @id @default(cuid())
  recipientId  String
  recipient    User                @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  
  type         NotificationType
  message      String
  taskId       String?
  task         Task?               @relation(fields: [taskId], references: [id], onDelete: SetNull)
  
  read         Boolean             @default(false)
  readAt       DateTime?
  
  deliveryLogs DeliveryLog[]
  
  createdAt    DateTime            @default(now())

  @@index([recipientId])
  @@index([taskId])
  @@index([read])
  @@index([createdAt])
}

model DeliveryLog {
  id            String                  @id @default(cuid())
  notificationId String
  notification  Notification            @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  
  taskId        String?
  task          Task?                   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  
  channel       NotificationChannel
  provider      String                  // "msg91", "gupshup"
  status        WhatsAppDeliveryStatus  @default(PENDING)
  externalId    String?                 // message ID from provider
  errorMessage  String?
  
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([notificationId])
  @@index([taskId])
  @@index([channel])
  @@index([status])
}

model ActivityLog {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  action    String   // "created", "started", "completed", "approved", "returned", "commented"
  details   String?  // JSON stringified details
  
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([userId])
  @@index([createdAt])
}
